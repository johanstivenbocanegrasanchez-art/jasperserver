2026-05-28T10:53:49,556  WARN Validator,pool-4-thread-2:552 - Invalid SQL:Se ha producido un error. Póngase en contacto con el administrador del sistema. (6632), SQL: WITH FM AS (
    SELECT 
        NIT, 
        MIN(FECHA_INGRESO) AS FECHA_PRIMER_CONTRATO
    FROM EMPLEADO
    WHERE EMPRESA NOT IN ('BAD', 'BA2')
    GROUP BY NIT
)

SELECT  
    E.FONDO,
    E.CENTRO_COSTO,

    E.PRIMER_APELLIDO || ' ' || E.SEGUNDO_APELLIDO AS APELLIDOS,
    E.NOMBRE,
    E.NIT AS CEDULA,

    E.EMPLEADO AS NOMINA,
    E.EMPLEADO,

    PA.NOMBRE_PAIS || ' ' || DEP.NOMBRE_DEPARTAMENTO || ' ' || POB.NOMBRE_POBLACION 
        AS NACIONALIDAD_LUGAR_NACIMIENTO,

    P.SEXO AS GENERO,

    TO_CHAR(E.FECHA_NACIMIENTO, 'DD/MM/YYYY') AS FECHA_NACIMIENTO,
    TRUNC(MONTHS_BETWEEN(SYSDATE, E.FECHA_NACIMIENTO) / 12) AS EDAD,

    P.DIRECCION,
    P.TELEFONO,
    P.CELULAR,

    UPPER(NVL(C.EMAIL, 'N/A')) AS EMAIL,

    D.NOMBRE_DEPENDENCIA AS NOMBRE_DEPENDENCIA,
    CC.NOMBRE_CENTRO_COSTO AS CENTRO_COSTO_PROGRAMA,

    CAT.NOMBRE_CATEGORIA AS CATEGORIA,
    CA.NOMBRE_CARGO AS CARGO,
    F.VALOR_FIJO AS SALARIO,

    TO_CHAR(E.FECHA_INGRESO, 'DD/MM/YYYY') AS INICIO_CONTRATO,
    TO_CHAR(E.FECHA_FIN_CONTRATO, 'DD/MM/YYYY') AS FIN_CONTRATO,

    M.DESCRIPCION_MOTIVO AS DESCRIPCION_MOTIVO,

    TC.DESCRIPCION AS TIPO_CONTRATO,
    TE.DESCRIPCION AS TIPO_EMPLEADO,
    E.ESTADO,

    TO_CHAR(E.MANTENER_SS_HASTA, 'DD/MM/YYYY') AS FECHA_MMS,

    TO_CHAR(FM.FECHA_PRIMER_CONTRATO, 'DD/MM/YYYY') AS FECHA_PRIMER_CONTRATO

FROM EMPLEADO E

JOIN PERSONA_TH P 
    ON P.NIT = E.NIT

JOIN FM 
    ON FM.NIT = E.NIT

LEFT JOIN FIJO F 
    ON F.EMPLEADO = E.EMPLEADO
    AND F.EMPRESA = E.EMPRESA
    AND F.CONCEPTO = 3

JOIN CENTRO_COSTO CC 
    ON CC.ORGANIZACION = E.ORGANIZACION
    AND CC.CENTRO_COSTO = E.CENTRO_COSTO

JOIN CATEGORIA_TH CAT 
    ON CAT.CATEGORIA = E.CATEGORIA

JOIN CARGO CA 
    ON CA.CARGO = E.CARGO
    AND CA.GRADO = E.GRADO
    AND CA.NIVEL = E.NIVEL

JOIN TIPO_EMPLEADO TE 
    ON TE.TIPO_EMPLEADO = E.TIPO_EMPLEADO

JOIN DEPENDENCIA D 
    ON D.DEPENDENCIA = E.DEPENDENCIA

LEFT JOIN MOTIVO M 
    ON M.MOTIVO = E.MOTIVO

LEFT JOIN (
    SELECT 
        TIPO_CONTRATO,
        DECODE (DESCRIPCION,
            'PERIODO ACADEMICO TC OBRA', 'PERIODO ACADEMICO TC',
            'PERIODO ACADEMICO HC OBRA', 'PERIODO ACADEMICO HC',
            'PERIODO ACADEMICO MT OBRA', 'PERIODO ACADEMICO MT',
            'NO APLICA', 'NO APLICA',
            'CONTRATO TERMINO FIJO INTEGRAL', 'CONTRATO TERMINO FIJO INTEGRAL',
            'CONTRATO TERMINO FIJO', 'CONTRATO TERMINO FIJO',
            'CONTRATO INDEFINIDO INTEGRAL', 'CONTRATO INDEFINIDO INTEGRAL',
            'CONTRATO A TERMINO INDEFINIDO', 'CONTRATO A TERMINO INDEFINIDO',
            'CONTRATO APRENDIZAJE', 'CONTRATO APRENDIZAJE',
            'CONTRATO LABOR U OBRA', 'CONTRATO LABOR U OBRA',
            'CONTRATO POR HONORARIOS', 'CONTRATO POR HONORARIOS',
            'CONTRATO TERM INDEFINIDO ADM', 'CONTRATO TERM INDEFINIDO ADM',
            'CONTRATO TERMINO FIJO ADM', 'CONTRATO TERMINO FIJO ADM'
        ) AS DESCRIPCION,
        AGRUPADOR
    FROM TIPO_CONTRATO
) TC 
    ON E.TIPO_CONTRATO = TC.TIPO_CONTRATO

LEFT JOIN (
    SELECT IDENTIFICACION, MAX(EMAIL) AS EMAIL
    FROM ICEBERG.UGC_CONTROL_CORREOS
    WHERE UPPER(EMAIL) LIKE '%UGC.EDU.CO'
    GROUP BY IDENTIFICACION
) C 
    ON C.IDENTIFICACION = P.NIT

JOIN PAIS PA 
    ON PA.PAIS = P.PAIS_NACIMIENTO

JOIN DEPARTAMENTO DEP 
    ON DEP.PAIS = PA.PAIS
    AND DEP.DEPARTAMENTO = P.DEPARTAMENTO_NACIMIENTO

JOIN POBLACION POB 
    ON POB.PAIS = PA.PAIS
    AND POB.DEPARTAMENTO = DEP.DEPARTAMENTO
    AND POB.POBLACION = P.POBLACION_NACIMIENTO

WHERE 
    E.EMPRESA = NVL(?, E.EMPRESA)
    AND E.FECHA_INGRESO BETWEEN 
        NVL(TO_DATE(?, 'DD/MM/YYYY'), E.FECHA_INGRESO)
        AND NVL(TO_DATE(?, 'DD/MM/YYYY'), E.FECHA_FIN_CONTRATO)
    AND CC.CENTRO_COSTO = NVL(?, CC.CENTRO_COSTO)
    AND CAT.CATEGORIA = NVL(?, CAT.CATEGORIA)
    AND CA.CARGO = NVL(?, CA.CARGO)
    AND E.NIT = NVL(?, E.NIT)
    AND E.ESTADO = NVL(?, E.ESTADO)
    AND E.TIPO_EMPLEADO = NVL(?, E.TIPO_EMPLEADO)
    AND E.DEPENDENCIA = NVL(?, E.DEPENDENCIA)
    AND E.FONDO LIKE ? || '%'

ORDER BY E.PRIMER_APELLIDO
